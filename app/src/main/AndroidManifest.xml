<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.byd.dashcast">

    <!-- ===== PERMISSIONS BYD AUTO API ===== -->

    <!-- Auto-Boot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>

    <!-- Foreground Service pour maintenir la projection cluster en background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>

    <!-- Connexion TCP localhost:5555 pour dadb (ADB local → popup autorisation) -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Floating overlay for the cluster control panel (interaction without leaving the app) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>

    <!-- Input event injection (required to control the cluster app from the main screen)
         This is a signature permission — granted by the BYD platform.keystore signature -->
    <uses-permission android:name="android.permission.INJECT_EVENTS"/>

    <!-- Miroir SurfaceControl — capturer le layer stack du cluster dans notre SurfaceView
         Signature permission: granted when our cert == platform cert (the case here with platform.keystore) -->
    <uses-permission android:name="android.permission.ACCESS_SURFACE_FLINGER"/>

    <!-- Body / Vehicle (COMMON = mandatory at runtime before getInstance) -->
    <uses-permission android:name="android.permission.BYDAUTO_BODYWORK_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_BODYWORK_GET"/>

    <!-- Climatisation -->
    <uses-permission android:name="android.permission.BYDAUTO_AC_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_AC_GET"/>
    <uses-permission android:name="android.permission.BYDAUTO_AC_SET"/>

    <!-- Vitesse -->
    <uses-permission android:name="android.permission.BYDAUTO_SPEED_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_SPEED_GET"/>

    <!-- Sensors (brightness, gyroscope…) -->
    <uses-permission android:name="android.permission.BYDAUTO_SENSOR_GET"/>

    <!-- Door lock (real name on DiLink 3.0: DOOR_LOCK with underscore) -->
    <uses-permission android:name="android.permission.BYDAUTO_DOOR_LOCK_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_DOOR_LOCK_GET"/>
    <uses-permission android:name="android.permission.BYDAUTO_DOOR_LOCK_SET"/>

    <!-- Moteur -->
    <uses-permission android:name="android.permission.BYDAUTO_ENGINE_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_ENGINE_GET"/>

    <!-- Energy (battery, fuel) -->
    <uses-permission android:name="android.permission.BYDAUTO_ENERGY_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_ENERGY_GET"/>

    <!-- Gearbox -->
    <uses-permission android:name="android.permission.BYDAUTO_GEARBOX_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_GEARBOX_GET"/>

    <!-- Tableau de bord -->
    <uses-permission android:name="android.permission.BYDAUTO_INSTRUMENT_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_INSTRUMENT_GET"/>

    <!-- OTA update: install APK packages -->
    <!-- REQUEST_INSTALL_PACKAGES: required on API 26+ to install APKs -->
    <!-- INSTALL_PACKAGES: signature permission — granted via platform.keystore → silent install -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>
    <uses-permission android:name="android.permission.INSTALL_PACKAGES"/>

    <!-- Lighting -->
    <uses-permission android:name="android.permission.BYDAUTO_LIGHT_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_LIGHT_GET"/>
    <uses-permission android:name="android.permission.BYDAUTO_LIGHT_SET"/>

    <!-- Pneus -->
    <uses-permission android:name="android.permission.BYDAUTO_TYRE_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_TYRE_GET"/>

    <!-- Radars de stationnement -->
    <uses-permission android:name="android.permission.BYDAUTO_RADAR_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_RADAR_GET"/>

    <!-- Confirmed required to launch on the cluster display (DiLink 3.0).
         INTERNAL_SYSTEM_WINDOW: signature permission granted with platform.keystore.
         MANAGE_ACTIVITY_STACKS (signature|privileged) : requis pour setLaunchDisplayId()
           vers une app TIERCE (Navigation = com.telenav.app.arp) sur display non-default.
           Granted automatically with platform.keystore (confirmed: INJECT_EVENTS OK). -->
    <uses-permission android:name="android.permission.INTERNAL_SYSTEM_WINDOW"/>
    <uses-permission android:name="android.permission.MANAGE_ACTIVITY_STACKS"/>
    <!-- Miroir cluster : capture du display 1 via SurfaceControl.screenshot() -->
    <uses-permission android:name="android.permission.READ_FRAME_BUFFER"/>

    <application
        android:name=".DashCastApp"
        android:extractNativeLibs="false"
        android:allowBackup="true"
        android:hardwareAccelerated="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/AppTheme">

        <!-- Welcome screen: language selection (first launch only) -->
        <activity
            android:name=".WelcomeActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Main 15.6" screen -->
        <activity
            android:name=".MainActivity"
            android:screenOrientation="landscape"/>

        <!-- Compatibility diagnostic screen -->
        <activity
            android:name=".DiagActivity"
            android:label="Diagnostic"
            android:screenOrientation="landscape"/>

        <!-- Full system report screen -->
        <activity
            android:name=".SysInfoActivity"
            android:label="System report"
            android:screenOrientation="landscape"/>

        <!-- Real-time log viewer -->
        <activity
            android:name=".LogActivity"
            android:label="Journal"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme.NoActionBar"
            android:launchMode="singleTop"/>

        <!-- User-facing settings (overscan tuning, cluster type) -->
        <activity
            android:name=".SettingsActivity"
            android:label="@string/settings_header"
            android:screenOrientation="landscape"
            android:parentActivityName=".MainActivity"/>

        <!-- Foreground Service : maintient la projection cluster en background -->
        <service
            android:name=".ClusterService"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

        <!-- Overlay service: quick-return icon to the streaming view -->
        <service
            android:name=".FloatingRemoteButton"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

        <!-- OTA: receives PackageInstaller session result -->
        <receiver
            android:name=".InstallResultReceiver"
            android:exported="false"/>

        <!-- FileProvider : partage de fichiers .log avec les apps externes (email, messagerie…) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- Auto-Boot Overscan restoration -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true"
            android:enabled="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
