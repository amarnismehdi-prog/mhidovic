<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Titre -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Diagnostic de compatibilité"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vérifie quel mécanisme est disponible pour envoyer des apps sur l'écran dashboard (instrument cluster)."
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginBottom="20dp"/>

        <!-- ======================== TEST 1 — ADB LOCAL ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 1 — Connexion ADB locale (dadb)"
            android:textColor="#A5D6A7"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Se connecte au daemon ADB de la tablette sur localhost:5555 (même mécanisme qu'Overdrive). Au premier lancement, un popup &#171;Autoriser le débogage USB ?&#187; apparaît — appuyez AUTORISER. Une fois autorisé, tente de débloquer toutes les permissions BYDAUTO_*_GET refusées via pm grant."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_adb_local"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connexion ADB locale + Grant permissions"
            android:textSize="14sp"
            android:backgroundTint="#2E7D32"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_adb_local_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appuyez sur le bouton pour lancer."
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#1A2A1A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_adb_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Partager le résultat TEST 1"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- TEST 2 : Restauration cluster -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 2 — Restauration cluster"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sur BYD DiLink 3.0, le cluster = display ID 1 dans IActivityManager (pas dans DisplayManager). sendInfo(1000,16) + am start --display 1."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_display1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ Lancer TEST 2"
            android:textSize="15sp"
            android:backgroundTint="#E65100"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_display1_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(résultat TEST 2)"
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="#1A1200"
            android:padding="8dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_display1_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Partager le résultat TEST 2"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- ======================== TEST 3 — DISPLAY SIZE ======================== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 3 — Taille display cluster (résolution Qt)"
            android:textColor="#80DEEA"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Taille écran cluster : cmd 29=8.8&quot; (Atto3/Dolphin) / cmd 30=12.3&quot; (Seal EU ✅) / cmd 31=10.25&quot;. Confirmé 16/04/2026 : cmd 30 = bonne résolution Seal EU. Rétablir : cmd30 + wm reset."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <!-- Ligne 1 : 3 boutons taille -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_display_size_88"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶ 8.8&quot;\n(cmd 29)\nAtto3/Dolphin"
                android:textSize="12sp"
                android:backgroundTint="#00695C"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_display_size_123"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶ 12.3&quot;\n(cmd 30)\nSeal EU ✅"
                android:textSize="12sp"
                android:backgroundTint="#1B5E20"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btn_display_size_1025"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶ 10.25&quot;\n(cmd 31)\nautres modèles"
                android:textSize="12sp"
                android:backgroundTint="#00695C"
                android:layout_marginStart="4dp"/>

        </LinearLayout>

        <!-- Ligne 2 : Rétablir -->
        <Button
            android:id="@+id/btn_display_size_restore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔄 Rétablir défaut (cmd 30 + wm reset)"
            android:textSize="13sp"
            android:backgroundTint="#6A1B9A"
            android:layout_marginBottom="8dp"/>

        <!-- Ligne 3 : Diagnostic complet -->
        <Button
            android:id="@+id/btn_display_size_full"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📊 Diagnostic complet (~8s)"
            android:textSize="13sp"
            android:backgroundTint="#00695C"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_display_size_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appuyez sur un bouton (ADB doit être autorisé — TEST 1 d&#39;abord)."
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#111A1A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_display_size_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Partager le résultat TEST 3"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- ======================== TEST 4 — BOOT RECEIVER ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 4 — BootReceiver Freedom (sans UI)"
            android:textColor="#FFCC00"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Envoie BOOT_COMPLETED directement au BootReceiver de Freedom (com.xdja.clusterdemo) via ADB, sans ouvrir son UI. Si ça crée le VirtualDisplay cluster → Freedom peut être lancé en headless."
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_boot_receiver"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ Lancer TEST 4 — Broadcast BootReceiver"
            android:textSize="13sp"
            android:backgroundTint="#4A1580"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_boot_receiver_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(résultat TEST 4)"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#111A1A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_boot_receiver_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Partager le résultat TEST 4"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

    
        <!-- Bloc Test Sniffer et Daemon -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Système — Daemon &amp; Sniffer"
            android:textColor="#FFCC00"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"/>

        <Button
            android:id="@+id/btn_test_daemon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lancer pseudo-daemon (Freedom IPC)"
            android:textSize="13sp"
            android:backgroundTint="#d81b60"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_start_sniffer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ Activer Sniffer Système (Arrière-plan)"
            android:textSize="13sp"
            android:backgroundTint="#811122"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_stop_sniffer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⏹ Arrêter Sniffer Système"
            android:textSize="13sp"
            android:backgroundTint="#d32f2f"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_export_sniffer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📤 Exporter le rapport du Sniffeur"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>
</LinearLayout>
</ScrollView>
