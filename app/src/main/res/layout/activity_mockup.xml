<?xml version="1.0" encoding="utf-8"?>
<!--
  MockupActivity layout — shows cluster map preview on main 15" display
  Framed in 8:3 aspect ratio container to simulate 1920×720 cluster screen
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0a0a14">

    <!-- Centered container preserving 8:3 aspect ratio -->
    <LinearLayout
        android:id="@+id/mockup_frame"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:paddingStart="48dp"
        android:paddingEnd="48dp">

        <!-- Preview label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APERÇU CLUSTER — 1920×720"
            android:textColor="#4488FF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.12"
            android:paddingBottom="8dp"/>

        <!-- Map container with 8:3 aspect ratio border -->
        <FrameLayout
            android:id="@+id/mockup_map_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2a2a3e">

            <!-- 8:3 aspect ratio enforcer — height set programmatically -->
            <com.google.android.gms.maps.MapView
                android:id="@+id/mockup_map_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <!-- Car cursor overlay — positioned to 78% from top programmatically -->
            <ImageView
                android:id="@+id/mockup_cursor"
                android:layout_width="40dp"
                android:layout_height="60dp"
                android:layout_gravity="top|center_horizontal"
                android:src="@drawable/ic_car_cursor"
                android:contentDescription="car"
                android:elevation="8dp"/>

            <!-- HUD strip overlay -->
            <LinearLayout
                android:id="@+id/mockup_hud"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:background="#BB000000"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/mockup_turn_icon"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_turn_straight"
                    android:tint="#FFFFFF"
                    android:contentDescription="turn"/>

                <TextView
                    android:id="@+id/mockup_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:paddingStart="12dp"/>

                <TextView
                    android:id="@+id/mockup_street"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text=""
                    android:textColor="#CCCCFF"
                    android:textSize="16sp"
                    android:paddingStart="8dp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/mockup_eta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Speed badge -->
            <LinearLayout
                android:id="@+id/mockup_speed_badge"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="12dp"
                android:background="#CC1a1a2e"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/mockup_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km/h"
                    android:textColor="#AAAACC"
                    android:textSize="9sp"/>
            </LinearLayout>
        </FrameLayout>

        <!-- Close button -->
        <Button
            android:id="@+id/btn_close_mockup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Fermer l'aperçu"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2a2a3e"/>
    </LinearLayout>

</FrameLayout>
