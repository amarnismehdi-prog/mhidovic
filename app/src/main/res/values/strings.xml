    <!-- DiagActivity — layout labels -->
    <string name="diag_title">Diagnostic de compatibilité</string>
    <string name="diag_subtitle">Vérifie quel mécanisme est disponible pour envoyer des apps sur l\'écran dashboard (instrument cluster).</string>
    <string name="diag_test1_title">TEST 1 — Connexion ADB locale (dadb)</string>
    <string name="diag_test1_desc">Se connecte au daemon ADB de la tablette sur localhost:5555 (même mécanisme qu\'Overdrive). Au premier lancement, un popup «Autoriser le débogage USB ?» apparaît — appuyez AUTORISER. Une fois autorisé, tente de débloquer toutes les permissions BYDAUTO_*_GET refusées via pm grant.</string>
    <string name="btn_adb_local_label">Connexion ADB locale + Grant permissions</string>
    <string name="diag_press_hint">Appuyez sur le bouton pour lancer.</string>
    <string name="diag_share_result1_btn">Partager le résultat TEST 1</string>
    <string name="diag_test2_title">TEST 2 — Restauration cluster</string>
    <string name="diag_test2_desc">Sur BYD DiLink 3.0, le cluster = display ID 1 dans IActivityManager (pas dans DisplayManager). sendInfo(1000,16) + am start --display 1.</string>
    <string name="diag_launch_test2_btn">▶ Lancer TEST 2</string>
    <string name="diag_result_test2_hint">(résultat TEST 2)</string>
    <string name="diag_share_result2_btn">Partager le résultat TEST 2</string>
    <string name="diag_test3_title">TEST 3 — Taille display cluster (résolution Qt)</string>
    <string name="diag_test3_desc">Taille écran cluster : cmd 29=8,8\" (Atto3/Dolphin) / cmd 30=12,3\" (Seal EU ✅) / cmd 31=10,25\". Confirmé 16/04/2026 : cmd 30 = bonne résolution Seal EU. Rétablir : cmd30 + wm reset.</string>
    <string name="diag_size_88_btn">▶ 8,8\"\n(cmd 29)\nAtto3/Dolphin</string>
    <string name="diag_size_123_btn">▶ 12,3\"\n(cmd 30)\nSeal EU ✅</string>
    <string name="diag_size_1025_btn">▶ 10,25\"\n(cmd 31)\nautres modèles</string>
    <string name="diag_size_restore_btn">🔄 Rétablir défaut (cmd 30 + wm reset)</string>
    <string name="diag_size_full_btn">📊 Diagnostic complet (~8 s)</string>
    <string name="diag_test3_hint_text">Appuyez sur un bouton (ADB doit être autorisé — TEST 1 d\'abord).</string>
    <string name="diag_share_result3_btn">Partager le résultat TEST 3</string>
    <string name="diag_test4_title">TEST 4 — BootReceiver Freedom (sans UI)</string>
    <string name="diag_test4_desc">Envoie BOOT_COMPLETED directement au BootReceiver de Freedom (com.xdja.clusterdemo) via ADB, sans ouvrir son UI. Si ça crée le VirtualDisplay cluster → Freedom peut être lancé en headless.</string>
    <string name="diag_launch_test4_btn">▶ Lancer TEST 4 — Broadcast BootReceiver</string>
    <string name="diag_result_test4_hint">(résultat TEST 4)</string>
    <string name="diag_share_result4_btn">Partager le résultat TEST 4</string>
    <string name="diag_test5_title">TEST 5 — Gestion MirrorDaemon (uid=2000)</string>
    <string name="diag_test5_desc">Vérifie et contrôle le processus MirrorDaemon (com.byd.myapp.mirrordaemon). Plusieurs instances simultanées causent un écran noir.</string>
    <string name="diag_scan_daemon_btn">🔍 Scanner les MirrorDaemon actifs</string>
    <string name="diag_scan_result_hint">(résultat scan)</string>
    <string name="diag_kill_daemon_btn">☠ Tuer tous les MirrorDaemon</string>
    <string name="diag_kill_restart_daemon_btn">🔄 Tuer + Relancer MirrorDaemon (propre)</string>
    <string name="diag_export_daemon_log_btn">📋 Exporter mirrordaemon.log</string>
    <string name="diag_dump_sf_btn">🔬 Dump SurfaceFlinger (byd_myapp_mirror)</string>
    <string name="diag_dump_sf_result_hint">(résultat dump SF)</string>
    <string name="diag_clean_daemon_btn">🗑 Supprimer tous les mirrordaemon*.log</string>
    <string name="diag_test6_title">TEST 6 — Sniffer Système</string>
    <string name="diag_test6_desc">Capture logcat filtré + snapshots dumpsys toutes les 30 s en arrière-plan.</string>
    <string name="diag_scan_sniffer_btn">🔍 Scanner les processus Sniffer actifs</string>
