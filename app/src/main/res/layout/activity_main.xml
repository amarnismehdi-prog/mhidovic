<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- ===== BARRE DE STATUT DASHBOARD ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/bg_top_bar"
        android:padding="12dp">

        <!-- Status dot: grey=off, yellow=pending, green=active -->
        <View
            android:id="@+id/view_status_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="8dp"
            android:background="#888888"/>

        <TextView
            android:id="@+id/tv_dashboard_status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/status_disconnected"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/btn_activate_cluster"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_activate_cluster"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:textColor="@color/text_primary"
            android:backgroundTint="#1976D2"/>

        <Button
            android:id="@+id/btn_show_mirror"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_show_mirror"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginStart="6dp"
            android:textColor="@color/text_primary"
            android:backgroundTint="#00897B"
            android:visibility="gone"/>

        <Button
            android:id="@+id/btn_restore_cluster"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_restore_cluster"
            android:textSize="12sp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginStart="6dp"
            android:textColor="@color/text_primary"
            android:backgroundTint="#D32F2F"/>

        <!-- ⋮ : settings + dev tools (Diag, Report, Log, Language, etc.) -->
        <Button
            android:id="@+id/btn_overflow"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="⋮"
            android:textSize="18sp"
            android:padding="0dp"
            android:layout_marginStart="8dp"
            android:contentDescription="@string/app_name"/>
    </LinearLayout>

    <!-- ===== EN-TÊTE LISTE + BARRE DE RECHERCHE ===== -->
    <LinearLayout
        android:id="@+id/ll_app_list_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title row: label + list/grid toggle button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@color/bg_top_bar"
            android:paddingStart="12dp"
            android:paddingEnd="4dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_app_list"
                android:textSize="16sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btn_view_toggle"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:text="⊞"
                android:textSize="16sp"
                android:padding="0dp"
                android:backgroundTint="#DDDDDD"
                android:textColor="@color/text_primary"
                android:contentDescription="@string/menu_view_grid"/>

        </LinearLayout>

        <!-- Search bar -->
        <EditText
            android:id="@+id/et_search_apps"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:hint="@string/hint_search_apps"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@color/bg_button_secondary"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"
            android:drawableStart="@android:drawable/ic_menu_search"
            android:drawablePadding="8dp"
            android:textSize="14sp"/>

    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

    <!-- ===== LISTE DES APPS ===== -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_apps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical"/>

    <!-- ===== MIROIR CLUSTER =====
         Wrapper FrameLayout contenant le SurfaceView miroir ET un placeholder texte.
         TextureView requires ACCESS_SURFACE_FLINGER (system permission):
         if unavailable, the placeholder is shown instead. -->
    <FrameLayout
        android:id="@+id/frame_cluster_mirror"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <!-- TextureView: SF est le PRODUCTEUR (il rend le contenu du display dans la surface).
             new Surface(textureView.getSurfaceTexture()) = surface SF writes into → TextureView displays.
             SurfaceView.getSurface() was wrong: the app was the producer, not SF. -->
        <TextureView
            android:id="@+id/cluster_mirror"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Miroir"/>

        <!-- Fallback screencap when SurfaceControl.createDisplay() fails (ROM permissions) -->
        <ImageView
            android:id="@+id/cluster_mirror_screenshot"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:background="@color/bg_main"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Screenshot"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tv_mirror_placeholder"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/mirror_placeholder"
            android:textColor="@color/text_accent"
            android:textSize="18sp"
            android:background="@color/bg_main"
            android:visibility="gone"/>

        <!-- Overlay: shows inset margins during resize adjustment -->
        <com.byd.dashcast.InsetOverlayView
            android:id="@+id/inset_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clickable="false"
            android:focusable="false"/>

    </FrameLayout>

    <!-- ===== CLUSTER CONTROL PANEL =====
         Shown only when a third-party app is active on the cluster.
         Allows controlling the app from the main screen (cluster is non-touch). -->
    <LinearLayout
        android:id="@+id/panel_cluster_control"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?android:attr/windowBackground"
        android:visibility="gone"
        android:layout_alignParentBottom="true">

        <!-- Collapse strip: always visible, toggles controls below -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="26dp"
            android:orientation="horizontal"
            android:gravity="end|center_vertical"
            android:background="@color/bg_card"
            android:paddingEnd="4dp">

            <Button
                android:id="@+id/btn_panel_toggle"
                android:layout_width="60dp"
                android:layout_height="22dp"
                android:text="&#9660;"
                android:textSize="10sp"
                android:padding="0dp"
                android:backgroundTint="@color/bg_button_secondary"
                android:textColor="@color/text_secondary"/>

        </LinearLayout>

        <!-- Collapsible controls (header row + resize zone) -->
        <LinearLayout
            android:id="@+id/panel_controls_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <!-- Header: app name + action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp"
            android:background="@color/bg_top_bar">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/cluster_control_title"
                android:textColor="@color/text_accent"
                android:textSize="12sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tv_control_app_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1"/>

            <Button
                android:id="@+id/btn_toggle_resize"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="@string/btn_adjust"
                android:textSize="10sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#00838F"/>

            <Button
                android:id="@+id/btn_relaunch"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:text="&#8635;"
                android:textSize="14sp"
                android:padding="0dp"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#E65100"
                android:textColor="@color/text_primary"
                android:contentDescription="@string/btn_relaunch"/>

            <Button
                android:id="@+id/btn_cluster_split"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="@string/btn_cluster_split"
                android:textSize="10sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:layout_marginEnd="6dp"
                android:backgroundTint="#5C6BC0"/>

            <Button
                android:id="@+id/btn_control_hide"
                android:layout_width="wrap_content"
                android:layout_height="30dp"
                android:text="@string/cluster_control_hide"
                android:textSize="10sp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"/>


        </LinearLayout>


        <!-- === ZONE REDIMENSIONNEMENT === -->
        <LinearLayout
            android:id="@+id/panel_resize"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:background="@color/bg_dialog"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/tv_resize_w_label"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_width_inset"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"/>
                <SeekBar
                    android:id="@+id/sb_resize_w"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="400"/>
                <TextView
                    android:id="@+id/tv_resize_w_val"
                    android:layout_width="35dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_accent"
                    android:textSize="12sp"
                    android:text="0"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                <TextView
                    android:id="@+id/tv_resize_h_label"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="@string/label_height_inset"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp"/>
                <SeekBar
                    android:id="@+id/sb_resize_h"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="400"/>
                <TextView
                    android:id="@+id/tv_resize_h_val"
                    android:layout_width="35dp"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_accent"
                    android:textSize="12sp"
                    android:text="0"/>
            </LinearLayout>

            <Button
                android:id="@+id/btn_resize_apply"
                android:layout_width="wrap_content"
                android:layout_height="35dp"
                android:layout_gravity="end"
                android:layout_marginTop="4dp"
                android:text="@string/btn_apply"
                android:textSize="12sp"
                android:backgroundTint="#2EA043"/>
        </LinearLayout>

        </LinearLayout> <!-- end panel_controls_content -->

    </LinearLayout>

    </RelativeLayout>

</LinearLayout>