    <!-- DiagActivity — layout labels -->
    <string name="diag_title">Kompatibilitätsdiagnose</string>
    <string name="diag_subtitle">Prüft, welcher Mechanismus verfügbar ist, um Apps auf den Dashboard-Bildschirm (Instrument Cluster) zu senden.</string>
    <string name="diag_test1_title">TEST 1 — Lokale ADB-Verbindung (dadb)</string>
    <string name="diag_test1_desc">Verbindet sich mit dem ADB-Daemon der Tablette auf localhost:5555 (gleicher Mechanismus wie Overdrive). Beim ersten Start erscheint ein Popup «USB-Debugging erlauben?» — ERLAUBEN drücken. Danach werden alle verweigerten BYDAUTO_*_GET-Berechtigungen via pm grant entsperrt.</string>
    <string name="diag_press_hint">Schaltfläche drücken, um zu starten.</string>
    <string name="diag_share_result1_btn">TEST 1-Ergebnis teilen</string>
    <string name="diag_test2_title">TEST 2 — Cluster-Wiederherstellung</string>
    <string name="diag_test2_desc">Bei BYD DiLink 3.0 ist der Cluster = Display-ID 1 in IActivityManager (nicht in DisplayManager). sendInfo(1000,16) + am start --display 1.</string>
    <string name="diag_launch_test2_btn">▶ TEST 2 starten</string>
    <string name="diag_result_test2_hint">(TEST 2-Ergebnis)</string>
    <string name="diag_share_result2_btn">TEST 2-Ergebnis teilen</string>
    <string name="diag_test3_title">TEST 3 — Cluster-Display-Größe (Qt-Auflösung)</string>
    <string name="diag_test3_desc">Cluster-Bildschirmgröße: cmd 29=8,8\" (Atto3/Dolphin) / cmd 30=12,3\" (Seal EU ✅) / cmd 31=10,25\". Bestätigt 16/04/2026: cmd 30 = korrekte Seal EU-Auflösung. Zurücksetzen: cmd30 + wm reset.</string>
    <string name="diag_size_88_btn">▶ 8,8\"\n(cmd 29)\nAtto3/Dolphin</string>
    <string name="diag_size_123_btn">▶ 12,3\"\n(cmd 30)\nSeal EU ✅</string>
    <string name="diag_size_1025_btn">▶ 10,25\"\n(cmd 31)\nandere Modelle</string>
    <string name="diag_size_restore_btn">🔄 Standard wiederherstellen (cmd 30 + wm reset)</string>
    <string name="diag_size_full_btn">📊 Volldiagnose (~8 s)</string>
    <string name="diag_test3_hint_text">Schaltfläche drücken (ADB muss autorisiert sein — zuerst TEST 1 ausführen).</string>
    <string name="diag_share_result3_btn">TEST 3-Ergebnis teilen</string>
    <string name="diag_launch_test4_btn">▶ TEST 4 starten — Broadcast BootReceiver</string>
    <string name="diag_result_test4_hint">(TEST 4-Ergebnis)</string>
    <string name="diag_share_result4_btn">TEST 4-Ergebnis teilen</string>
    <string name="diag_test5_title">TEST 5 — MirrorDaemon-Verwaltung (uid=2000)</string>
    <string name="diag_test5_desc">Prüft und steuert den MirrorDaemon-Prozess (com.byd.myapp.mirrordaemon). Mehrere gleichzeitige Instanzen verursachen einen schwarzen Bildschirm.</string>
    <string name="diag_scan_daemon_btn">🔍 Aktive MirrorDaemon scannen</string>
    <string name="diag_scan_result_hint">(Scan-Ergebnis)</string>
    <string name="diag_kill_daemon_btn">☠ Alle MirrorDaemon beenden</string>
    <string name="diag_kill_restart_daemon_btn">🔄 MirrorDaemon beenden + neu starten</string>
