    <!-- DiagActivity — layout labels -->
    <string name="diag_title">Compatibility Diagnostic</string>
    <string name="diag_subtitle">Checks which mechanism is available to send apps to the dashboard screen (instrument cluster).</string>
    <string name="diag_test1_title">TEST 1 — Local ADB connection (dadb)</string>
    <string name="diag_test1_desc">Connects to the tablet\'s ADB daemon on localhost:5555 (same mechanism as Overdrive). On first launch, a popup «Allow USB debugging?» appears — press ALLOW. Once authorized, attempts to unlock all denied BYDAUTO_*_GET permissions via pm grant.</string>
    <string name="btn_adb_local_label">Local ADB connection + Grant permissions</string>
    <string name="diag_press_hint">Press the button to start.</string>
    <string name="diag_share_result1_btn">Share TEST 1 result</string>
    <string name="diag_test2_title">TEST 2 — Cluster restoration</string>
    <string name="diag_test2_desc">On BYD DiLink 3.0, the cluster = display ID 1 in IActivityManager (not in DisplayManager). sendInfo(1000,16) + am start --display 1.</string>
    <string name="diag_launch_test2_btn">▶ Launch TEST 2</string>
    <string name="diag_result_test2_hint">(TEST 2 result)</string>
    <string name="diag_share_result2_btn">Share TEST 2 result</string>
    <string name="diag_test3_title">TEST 3 — Cluster display size (Qt resolution)</string>
    <string name="diag_test3_desc">Cluster screen size: cmd 29=8.8\" (Atto3/Dolphin) / cmd 30=12.3\" (Seal EU ✅) / cmd 31=10.25\". Confirmed 16/04/2026: cmd 30 = correct Seal EU resolution. Restore: cmd30 + wm reset.</string>
    <string name="diag_size_88_btn">▶ 8.8\"\n(cmd 29)\nAtto3/Dolphin</string>
    <string name="diag_size_123_btn">▶ 12.3\"\n(cmd 30)\nSeal EU ✅</string>
    <string name="diag_size_1025_btn">▶ 10.25\"\n(cmd 31)\nother models</string>
    <string name="diag_size_restore_btn">🔄 Restore default (cmd 30 + wm reset)</string>
    <string name="diag_size_full_btn">📊 Full diagnostic (~8s)</string>
    <string name="diag_test3_hint_text">Press a button (ADB must be authorized — run TEST 1 first).</string>
    <string name="diag_share_result3_btn">Share TEST 3 result</string>
    <string name="diag_test4_title">TEST 4 — BootReceiver Freedom (headless)</string>
    <string name="diag_test4_desc">Sends BOOT_COMPLETED directly to Freedom\'s BootReceiver (com.xdja.clusterdemo) via ADB, without opening its UI. If it creates the cluster VirtualDisplay → Freedom can be launched headless.</string>
    <string name="diag_launch_test4_btn">▶ Launch TEST 4 — Broadcast BootReceiver</string>
    <string name="diag_result_test4_hint">(TEST 4 result)</string>
    <string name="diag_share_result4_btn">Share TEST 4 result</string>
    <string name="diag_test5_title">TEST 5 — MirrorDaemon management (uid=2000)</string>
    <string name="diag_test5_desc">Checks and controls the MirrorDaemon process (com.byd.myapp.mirrordaemon). Multiple simultaneous instances cause a black screen.</string>
    <string name="diag_scan_daemon_btn">🔍 Scan active MirrorDaemon</string>
    <string name="diag_scan_result_hint">(scan result)</string>
    <string name="diag_kill_daemon_btn">☠ Kill all MirrorDaemon</string>
    <string name="diag_kill_restart_daemon_btn">🔄 Kill + Restart MirrorDaemon (clean)</string>
    <string name="diag_export_daemon_log_btn">📋 Export mirrordaemon.log</string>
    <string name="diag_dump_sf_btn">🔬 Dump SurfaceFlinger (byd_myapp_mirror)</string>
    <string name="diag_dump_sf_result_hint">(SF dump result)</string>
    <string name="diag_clean_daemon_btn">🗑 Delete all mirrordaemon*.log</string>
    <string name="diag_test6_title">TEST 6 — System Sniffer</string>
    <string name="diag_test6_desc">Captures filtered logcat + dumpsys snapshots every 30s in the background.</string>
    <string name="diag_scan_sniffer_btn">🔍 Scan active Sniffer processes</string>
    <string name="diag_sniffer_result_hint">(scan result)</string>
