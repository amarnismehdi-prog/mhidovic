<?xml version="1.0" encoding="utf-8"?>
<!-- DashCast — OsmAnd+ focused layout.
     Left pane: full-height cluster mirror + status strip + activate/restore buttons.
     Right pane: navigation card (address input, Naviguer, Arrêter, Redémarrer).
     Root FrameLayout hosts the fullscreen-exit FAB overlay. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_overlay"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_background"
    tools:ignore="HardcodedText,Overdraw">

<LinearLayout
    android:id="@+id/root_content"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:baselineAligned="false"
    android:orientation="horizontal">

    <!-- ════════════════════════════════════════════════ -->
    <!-- NAV RAIL                                         -->
    <!-- ════════════════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/ll_nav_rail"
        android:layout_width="88dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/md_surface_container_low"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <!-- Logo / long-press = overflow menu -->
        <ImageView
            android:id="@+id/iv_nav_logo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="20dp"
            android:scaleType="fitCenter"
            android:src="@mipmap/ic_launcher"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/app_name"/>

        <!-- Mirror (active) -->
        <LinearLayout
            android:id="@+id/nav_apps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <ImageView
                android:layout_width="56dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:tint="@color/md_on_secondary_container"
                android:background="@drawable/bg_nav_pill_active"
                android:src="@drawable/ic_navigation"
                android:contentDescription="@string/main_nav_apps"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/main_nav_apps"
                android:textSize="11sp"
                android:textColor="@color/md_on_surface"/>
        </LinearLayout>

        <!-- Settings -->
        <LinearLayout
            android:id="@+id/nav_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <ImageView
                android:layout_width="56dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:tint="@color/md_on_surface_variant"
                android:src="@drawable/ic_tune"
                android:contentDescription="@string/main_nav_settings"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/main_nav_settings"
                android:textSize="11sp"
                android:textColor="@color/md_on_surface_variant"/>
        </LinearLayout>

        <!-- Diag -->
        <LinearLayout
            android:id="@+id/nav_diag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <ImageView
                android:layout_width="56dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:tint="@color/md_on_surface_variant"
                android:src="@drawable/ic_stethoscope"
                android:contentDescription="@string/main_nav_diag"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/main_nav_diag"
                android:textSize="11sp"
                android:textColor="@color/md_on_surface_variant"/>
        </LinearLayout>

        <!-- Sysinfo -->
        <LinearLayout
            android:id="@+id/nav_sysinfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <ImageView
                android:layout_width="56dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:tint="@color/md_on_surface_variant"
                android:src="@drawable/ic_info"
                android:contentDescription="@string/main_nav_sysinfo"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/main_nav_sysinfo"
                android:textSize="11sp"
                android:textColor="@color/md_on_surface_variant"/>
        </LinearLayout>

        <!-- Log -->
        <LinearLayout
            android:id="@+id/nav_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="10dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <ImageView
                android:layout_width="56dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:tint="@color/md_on_surface_variant"
                android:src="@drawable/ic_notes"
                android:contentDescription="@string/main_nav_log"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/main_nav_log"
                android:textSize="11sp"
                android:textColor="@color/md_on_surface_variant"/>
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- Help (bottom) -->
        <LinearLayout
            android:id="@+id/nav_help"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?android:attr/selectableItemBackground">
            <ImageView
                android:layout_width="56dp"
                android:layout_height="32dp"
                android:padding="4dp"
                android:scaleType="fitCenter"
                android:tint="@color/md_on_surface_variant"
                android:src="@drawable/ic_help_outline"
                android:contentDescription="@string/main_nav_help"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/main_nav_help"
                android:textSize="11sp"
                android:textColor="@color/md_on_surface_variant"/>
        </LinearLayout>

    </LinearLayout>

    <!-- ════════════════════════════════════════════════ -->
    <!-- MAIN AREA                                        -->
    <!-- ════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- ────── TOP BAR ────── -->
        <LinearLayout
            android:id="@+id/ll_top_bar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/main_title_dashboard"
                android:textColor="@color/md_on_surface"
                android:textSize="22sp"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- ────── CONTENT ROW (left mirror + right nav) ────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <!-- ═══════════════════════════════════════ -->
            <!-- LEFT PANE: cluster mirror               -->
            <!-- ═══════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/ll_left_pane"
                android:layout_width="0dp"
                android:layout_weight="1.4"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_marginEnd="16dp">

                <!-- Mirror preview card — fills remaining height -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_cluster_preview"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#0F1115"
                    app:contentPadding="0dp">

                    <FrameLayout
                        android:id="@+id/frame_cluster_mirror"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <TextureView
                            android:id="@+id/cluster_mirror"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="@string/main_preview_section"/>

                        <ImageView
                            android:id="@+id/cluster_mirror_screenshot"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="fitCenter"
                            android:background="#0F1115"
                            android:clickable="true"
                            android:focusable="true"
                            android:contentDescription="@string/main_preview_section"
                            android:visibility="gone"/>

                        <TextView
                            android:id="@+id/tv_mirror_placeholder"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:text="@string/mirror_placeholder"
                            android:textColor="@color/md_on_surface_variant"
                            android:textSize="14sp"
                            android:visibility="gone"/>

                        <com.byd.dashcast.InsetOverlayView
                            android:id="@+id/inset_overlay"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:clickable="false"
                            android:focusable="false"/>

                        <!-- Fullscreen expand button (top-right corner of mirror) -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_show_mirror"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:layout_gravity="top|end"
                            android:layout_margin="8dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            app:cornerRadius="20dp"
                            app:icon="@drawable/ic_visibility"
                            app:iconGravity="textStart"
                            app:iconSize="18dp"
                            app:iconPadding="0dp"
                            android:contentDescription="@string/main_btn_full_preview"
                            android:visibility="gone"/>

                    </FrameLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Status strip -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingTop="10dp"
                    android:paddingBottom="4dp">

                    <View
                        android:id="@+id/view_status_dot"
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:layout_marginEnd="8dp"
                        android:background="#888888"/>

                    <TextView
                        android:id="@+id/tv_dashboard_status"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/main_cluster_status_off"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/md_on_surface"
                        android:ellipsize="end"
                        android:maxLines="1"/>

                </LinearLayout>

                <!-- Activate / Restore buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_activate_cluster"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="6dp"
                        android:text="@string/main_btn_reconnect"
                        android:textSize="13sp"
                        android:minHeight="48dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:cornerRadius="24dp"
                        app:icon="@drawable/ic_refresh"
                        app:iconGravity="textStart"
                        app:iconSize="18dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_restore_cluster"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="@string/main_btn_stop_mirror"
                        android:textSize="13sp"
                        android:minHeight="48dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:cornerRadius="24dp"
                        app:icon="@drawable/ic_stop"
                        app:iconGravity="textStart"
                        app:iconSize="18dp"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ═══════════════════════════════════════ -->
            <!-- RIGHT PANE: OsmAnd+ navigation          -->
            <!-- ═══════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/ll_right_pane"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_nav_control"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:cardBackgroundColor="@color/md_surface_container_low"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp"
                        android:gravity="top">

                        <!-- OsmAnd+ header -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_marginEnd="12dp"
                                android:scaleType="fitCenter"
                                android:src="@drawable/ic_navigation"
                                android:tint="@color/md_primary"
                                android:contentDescription="@null"/>

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="OsmAnd+"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/md_on_surface"/>

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/main_nav_section"
                                    android:textSize="12sp"
                                    android:textColor="@color/md_on_surface_variant"/>

                            </LinearLayout>

                        </LinearLayout>

                        <!-- Address input -->
                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/til_nav_address"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="@string/main_nav_address_hint"
                            app:endIconMode="clear_text">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_nav_address"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPostalAddress|textCapWords"
                                android:imeOptions="actionGo"
                                android:maxLines="1"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Naviguer -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_nav_go"
                            style="@style/Widget.Material3.Button"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="52dp"
                            android:text="@string/main_nav_btn_go"
                            android:textSize="15sp"
                            app:cornerRadius="26dp"
                            app:icon="@drawable/ic_navigation"
                            app:iconGravity="textStart"
                            app:iconSize="20dp"/>

                        <!-- Arrêter navigation -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_nav_stop"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="52dp"
                            android:text="@string/main_nav_btn_stop"
                            android:textSize="15sp"
                            app:cornerRadius="26dp"
                            app:icon="@drawable/ic_stop"
                            app:iconGravity="textStart"
                            app:iconSize="20dp"/>

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="16dp"/>

                        <!-- Redémarrer OsmAnd+ -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_restart_nav"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:minHeight="52dp"
                            android:text="@string/main_btn_restart_nav"
                            android:textSize="15sp"
                            app:cornerRadius="26dp"
                            app:icon="@drawable/ic_play_circle"
                            app:iconGravity="textStart"
                            app:iconSize="20dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </LinearLayout>
</LinearLayout>

    <!-- Fullscreen exit FAB (shown only in fullscreen mirror mode) -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_exit_fullscreen"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_close"
        android:contentDescription="@string/main_btn_exit_fullscreen"
        app:backgroundTint="@color/md_error_container"
        app:tint="@color/md_on_error_container"
        app:fabSize="mini"
        android:visibility="gone"/>

</FrameLayout>
