<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/md_surface">

    <!-- ============= Nav rail ============= -->
    <LinearLayout
        android:id="@+id/ll_nav_rail_log"
        android:layout_width="96dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@color/md_surface_container_low"
        android:paddingTop="14dp" android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/iv_nav_logo_log"
            android:layout_width="48dp" android:layout_height="48dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@string/app_name"
            android:clickable="true" android:focusable="true"/>

        <ImageView
            android:id="@+id/nav_apps_log"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="22dp"
            android:src="@drawable/ic_apps"
            android:padding="10dp"
            android:contentDescription="@string/main_nav_apps"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_apps"
            android:textSize="10sp" android:textColor="@color/md_on_surface_variant"
            android:layout_marginTop="2dp"/>

        <ImageView
            android:id="@+id/nav_settings_log"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:src="@drawable/ic_tune"
            android:padding="10dp"
            android:contentDescription="@string/main_nav_settings"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_settings"
            android:textSize="10sp" android:textColor="@color/md_on_surface_variant"
            android:layout_marginTop="2dp"/>

        <ImageView
            android:id="@+id/nav_diag_log"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:src="@drawable/ic_stethoscope"
            android:padding="10dp"
            android:contentDescription="@string/main_nav_diag"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_diag"
            android:textSize="10sp" android:textColor="@color/md_on_surface_variant"
            android:layout_marginTop="2dp"/>

        <ImageView
            android:id="@+id/nav_sysinfo_log"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:src="@drawable/ic_info"
            android:padding="10dp"
            android:contentDescription="@string/main_nav_sysinfo"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_sysinfo"
            android:textSize="10sp" android:textColor="@color/md_on_surface_variant"
            android:layout_marginTop="2dp"/>

        <ImageView
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:src="@drawable/ic_notes"
            android:padding="10dp"
            android:background="@drawable/bg_nav_pill_active"
            android:contentDescription="@string/main_nav_log"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_log"
            android:textSize="10sp" android:textColor="@color/md_primary"
            android:textStyle="bold"
            android:layout_marginTop="2dp"/>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
    </LinearLayout>

    <!-- ============= Main area ============= -->
    <LinearLayout
        android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="20dp" android:paddingBottom="12dp">

        <!-- Top bar: title + actions + clock -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/log_title"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/md_on_surface"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/log_btn_pause"
                style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
                android:layout_width="48dp" android:layout_height="48dp"
                android:layout_marginEnd="6dp"
                app:icon="@drawable/ic_pause"
                app:iconTint="@color/md_on_secondary_container"
                android:contentDescription="@string/log_btn_pause_cd"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/log_btn_clear"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp" android:layout_height="48dp"
                app:icon="@drawable/ic_delete"
                app:iconTint="@color/md_on_surface_variant"
                android:contentDescription="@string/log_btn_clear_cd"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/log_btn_share"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp" android:layout_height="48dp"
                app:icon="@drawable/ic_share"
                app:iconTint="@color/md_on_surface_variant"
                android:contentDescription="@string/log_btn_share_cd"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/log_btn_save"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp" android:layout_height="48dp"
                app:icon="@drawable/ic_save"
                app:iconTint="@color/md_on_surface_variant"
                android:contentDescription="@string/log_btn_save_cd"/>

            <TextClock
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:format12Hour="HH:mm"
                android:format24Hour="HH:mm"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/md_on_surface_variant"/>
        </LinearLayout>

        <!-- Filter row + level chips -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="44dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp" android:paddingEnd="14dp"
                android:background="@drawable/bg_log_filter">

                <ImageView
                    android:layout_width="20dp" android:layout_height="20dp"
                    android:src="@drawable/ic_filter_list"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="@string/log_filter_hint"/>

                <EditText
                    android:id="@+id/log_filter"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="@string/log_filter_hint"
                    android:textSize="13sp"
                    android:textColor="@color/md_on_surface"
                    android:textColorHint="@color/md_on_surface_variant"
                    android:background="@android:color/transparent"
                    android:singleLine="true"
                    android:inputType="text"
                    android:imeOptions="actionSearch"/>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/chip_all"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="10dp"
                android:textSize="12sp"
                android:text="@string/log_chip_all_zero"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/chip_info"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:text="@string/log_chip_info_zero"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/chip_warn"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:text="@string/log_chip_warn_zero"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/chip_error"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="6dp"
                android:textSize="12sp"
                android:text="@string/log_chip_error_zero"/>
        </LinearLayout>

        <!-- Log list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/log_recycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="vertical"/>

        <TextView
            android:id="@+id/log_empty_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/log_empty"
            android:textColor="@color/md_on_surface_variant"
            android:textSize="13sp"
            android:gravity="center"
            android:visibility="gone"/>
    </LinearLayout>
</LinearLayout>
