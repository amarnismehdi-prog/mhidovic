<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_card">

    <!-- Barre de titre + actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#222222"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/log_title"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <Button
            android:id="@+id/log_btn_clear"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/log_btn_clear"
            android:textSize="12sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:backgroundTint="#555555"/>

        <Button
            android:id="@+id/log_btn_share"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/log_btn_share"/>

    </LinearLayout>

    <!-- Filtre + auto-scroll -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#1C1C1C"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <EditText
            android:id="@+id/log_filter"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="@string/log_filter_hint"
            android:textColor="@color/text_primary"
            android:textColorHint="#666666"
            android:background="#2A2A2A"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textSize="12sp"
            android:singleLine="true"
            android:inputType="text"/>

        <CheckBox
            android:id="@+id/log_autoscroll"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/log_autoscroll"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

    <!-- Color legend -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="22dp"
        android:orientation="horizontal"
        android:background="#161616"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/log_level_debug" android:textColor="#999999" android:textSize="10sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/log_level_info" android:textColor="#DDDDDD" android:textSize="10sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/log_level_warn" android:textColor="#FFA040" android:textSize="10sp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/log_level_error" android:textColor="#FF4444" android:textSize="10sp"/>

    </LinearLayout>

    <!-- Zone de log scrollable -->
    <ScrollView
        android:id="@+id/log_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <TextView
            android:id="@+id/log_tv"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A1A"
            android:textColor="#DDDDDD"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/log_empty"/>

    </ScrollView>

</LinearLayout>
