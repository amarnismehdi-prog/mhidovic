<?xml version="1.0" encoding="utf-8"?>
<!-- Speed limit sign: white circle with red border (European standard) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Red ring -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#CC0000"/>
        </shape>
    </item>
    <!-- White inner circle -->
    <item
        android:top="5dp"
        android:left="5dp"
        android:right="5dp"
        android:bottom="5dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF"/>
        </shape>
    </item>
</layer-list>
