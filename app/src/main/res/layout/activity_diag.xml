<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:baselineAligned="false"
    android:background="?attr/colorSurface"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="Overdraw">

    <!-- ============= Nav rail ============= -->
    <LinearLayout
        android:id="@+id/ll_nav_rail_diag"
        android:layout_width="96dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@color/md_surface_container_low"
        android:paddingTop="14dp" android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/iv_nav_logo_diag"
            android:layout_width="48dp" android:layout_height="48dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@string/app_name"
            android:clickable="true" android:focusable="true"/>

        <ImageView
            android:id="@+id/nav_apps_diag"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="22dp"
            android:src="@drawable/ic_apps"
            android:padding="10dp"
            android:contentDescription="@string/main_nav_apps"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_apps"
            android:textSize="10sp" android:textColor="@color/md_on_surface_variant"
            android:layout_marginTop="2dp"/>

        <ImageView
            android:id="@+id/nav_settings_diag"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:src="@drawable/ic_tune"
            android:padding="10dp"
            android:contentDescription="@string/main_nav_settings"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_settings"
            android:textSize="10sp" android:textColor="@color/md_on_surface_variant"
            android:layout_marginTop="2dp"/>

        <ImageView
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:src="@drawable/ic_stethoscope"
            android:padding="10dp"
            android:background="@drawable/bg_nav_pill_active"
            android:contentDescription="@string/main_nav_diag"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_diag"
            android:textSize="10sp" android:textColor="@color/md_primary"
            android:textStyle="bold"
            android:layout_marginTop="2dp"/>

        <ImageView
            android:id="@+id/nav_sysinfo_diag"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:src="@drawable/ic_info"
            android:padding="10dp"
            android:contentDescription="@string/main_nav_sysinfo"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_sysinfo"
            android:textSize="10sp" android:textColor="@color/md_on_surface_variant"
            android:layout_marginTop="2dp"/>

        <ImageView
            android:id="@+id/nav_log_diag"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:src="@drawable/ic_notes"
            android:padding="10dp"
            android:contentDescription="@string/main_nav_log"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_log"
            android:textSize="10sp" android:textColor="@color/md_on_surface_variant"
            android:layout_marginTop="2dp"/>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
    </LinearLayout>

    <!-- ============= Main area ============= -->
    <LinearLayout
        android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="20dp" android:paddingBottom="20dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/main_nav_diag"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"/>

            <TextClock
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="HH:mm"
                android:format24Hour="HH:mm"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/md_on_surface_variant"/>
        </LinearLayout>

        <!-- Probe card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/md_outline_variant"
            app:cardBackgroundColor="@color/md_surface_container_low">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Header row: title + run button -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp" android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/diag_probe_title"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnSurface"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="@string/diag_probe_subtitle"
                            android:textSize="12sp"
                            android:textColor="@color/md_on_surface_variant"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_probe_run"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/diag_probe_run"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        app:icon="@drawable/ic_stethoscope"
                        app:iconSize="18dp"
                        app:iconGravity="textStart"
                        app:cornerRadius="20dp"/>
                </LinearLayout>

                <!-- Progress bar -->
                <ProgressBar
                    android:id="@+id/pb_probe"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="4dp"
                    android:layout_marginTop="14dp"
                    android:indeterminate="true"
                    android:visibility="gone"/>

                <!-- Status label -->
                <TextView
                    android:id="@+id/tv_probe_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/diag_probe_idle"
                    android:textSize="12sp"
                    android:textColor="@color/md_on_surface_variant"
                    android:visibility="gone"/>

                <!-- Output box -->
                <ScrollView
                    android:id="@+id/sv_probe_output"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_diag_output_box"
                    android:padding="12dp"
                    android:visibility="gone"
                    android:fadeScrollbars="false">

                    <TextView
                        android:id="@+id/tv_probe_output"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="monospace"
                        android:textSize="11sp"
                        android:textColor="?attr/colorOnSurface"
                        android:textIsSelectable="true"/>
                </ScrollView>

                <!-- Copy button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_probe_copy"
                    style="@style/Widget.Material3.Button.TonalButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/diag_probe_copy"
                    android:visibility="gone"
                    app:icon="@drawable/ic_copy"
                    app:iconSize="18dp"
                    app:iconGravity="textStart"
                    app:cornerRadius="20dp"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</LinearLayout>
