<?xml version="1.0" encoding="utf-8"?>
<!-- v0.9.82 — Generic SysInfo row used for displays & services lists.
     Tag the leading icon background to highlight running services. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <FrameLayout
        android:id="@+id/row_leading"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_diag_card_icon">
        <ImageView
            android:id="@+id/row_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:tint="@color/md_on_secondary_container"
            android:contentDescription="@null"/>
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:id="@+id/row_headline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/md_on_surface"/>
        <TextView
            android:id="@+id/row_support"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textSize="12sp"
            android:textColor="@color/md_on_surface_variant"/>
    </LinearLayout>

    <TextView
        android:id="@+id/row_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="@color/md_status_ok"
        android:background="@drawable/bg_status_pill_ok"/>
</LinearLayout>
