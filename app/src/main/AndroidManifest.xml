<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.byd.myapp">

    <!-- ===== PERMISSIONS BYD AUTO API ===== -->

    <!-- Foreground Service pour maintenir la projection cluster en background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>

    <!-- Connexion TCP localhost:5555 pour dadb (ADB local → popup autorisation) -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Overlay flottant pour le panneau de contrôle cluster (interaction sans quitter l'app) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>

    <!-- Injection d'événements input (requis pour piloter l'app cluster depuis l'écran principal)
         C'est une signature permission — accordée grâce à la signature platform.keystore BYD -->
    <uses-permission android:name="android.permission.INJECT_EVENTS"/>

    <!-- Carrosserie / Véhicule (COMMON = obligatoire en dynamique avant getInstance) -->
    <uses-permission android:name="android.permission.BYDAUTO_BODYWORK_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_BODYWORK_GET"/>

    <!-- Climatisation -->
    <uses-permission android:name="android.permission.BYDAUTO_AC_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_AC_GET"/>
    <uses-permission android:name="android.permission.BYDAUTO_AC_SET"/>

    <!-- Vitesse -->
    <uses-permission android:name="android.permission.BYDAUTO_SPEED_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_SPEED_GET"/>

    <!-- Capteurs (luminosité, gyroscope…) -->
    <uses-permission android:name="android.permission.BYDAUTO_SENSOR_GET"/>

    <!-- Verrouillage des portes (nom réel sur DiLink 3.0 : DOOR_LOCK avec underscore) -->
    <uses-permission android:name="android.permission.BYDAUTO_DOOR_LOCK_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_DOOR_LOCK_GET"/>
    <uses-permission android:name="android.permission.BYDAUTO_DOOR_LOCK_SET"/>

    <!-- Moteur -->
    <uses-permission android:name="android.permission.BYDAUTO_ENGINE_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_ENGINE_GET"/>

    <!-- Énergie (batterie, carburant) -->
    <uses-permission android:name="android.permission.BYDAUTO_ENERGY_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_ENERGY_GET"/>

    <!-- Boîte de vitesses -->
    <uses-permission android:name="android.permission.BYDAUTO_GEARBOX_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_GEARBOX_GET"/>

    <!-- Tableau de bord -->
    <uses-permission android:name="android.permission.BYDAUTO_INSTRUMENT_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_INSTRUMENT_GET"/>

    <!-- Éclairages -->
    <uses-permission android:name="android.permission.BYDAUTO_LIGHT_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_LIGHT_GET"/>
    <uses-permission android:name="android.permission.BYDAUTO_LIGHT_SET"/>

    <!-- Pneus -->
    <uses-permission android:name="android.permission.BYDAUTO_TYRE_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_TYRE_GET"/>

    <!-- Radars de stationnement -->
    <uses-permission android:name="android.permission.BYDAUTO_RADAR_COMMON"/>
    <uses-permission android:name="android.permission.BYDAUTO_RADAR_GET"/>

    <!-- Confirmé requis pour lancer sur le display cluster (DiLink 3.0).
         INTERNAL_SYSTEM_WINDOW : signature permission accordée avec platform.keystore.
         MANAGE_ACTIVITY_STACKS (signature|privileged) : requis pour setLaunchDisplayId()
           vers une app TIERCE (Navigation = com.telenav.app.arp) sur display non-default.
           Accordée automatiquement avec platform.keystore (confirmé : INJECT_EVENTS OK). -->
    <uses-permission android:name="android.permission.INTERNAL_SYSTEM_WINDOW"/>
    <uses-permission android:name="android.permission.MANAGE_ACTIVITY_STACKS"/>
    <!-- Miroir cluster : capture du display 1 via SurfaceControl.screenshot() -->
    <uses-permission android:name="android.permission.READ_FRAME_BUFFER"/>
    <uses-permission android:name="android.permission.ACCESS_SURFACE_FLINGER"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/AppTheme">

        <!-- Écran d'accueil : choix de langue (premier lancement uniquement) -->
        <activity
            android:name=".WelcomeActivity"
            android:label="@string/app_name"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Écran principal 15" -->
        <activity
            android:name=".MainActivity"
            android:label="@string/app_name"
            android:screenOrientation="landscape"/>

        <!-- Écran de diagnostic de compatibilité -->
        <activity
            android:name=".DiagActivity"
            android:label="Diagnostic"
            android:screenOrientation="landscape"/>

        <!-- Rapport système complet -->
        <activity
            android:name=".SysInfoActivity"
            android:label="Rapport système"
            android:screenOrientation="landscape"/>

        <!-- Visualiseur de journal en temps réel -->
        <activity
            android:name=".LogActivity"
            android:label="Journal"
            android:screenOrientation="landscape"
            android:theme="@style/AppTheme.NoActionBar"
            android:launchMode="singleTop"/>

        <!-- Trampoline display 1 : permet de lancer une app tierce sur le cluster
             en passant par notre propre uid (isCallerAllowedToLaunchOnDisplay
             retourne true quand targetUid == callingUid).
             EXPORTED=TRUE : le lancement se fait via ADB shell uid=2000
             qui possède INTERNAL_SYSTEM_WINDOW dans platform.xml de cette ROM.
             C'est exactement le pattern qui fonctionnait le 12 avril avec
             BYDDashboardActivity (aussi exported=true). -->
        <activity
            android:name=".dashboard.ClusterTrampolineActivity"
            android:exported="true"
            android:launchMode="standard"
            android:taskAffinity="com.byd.myapp.cluster"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"/>

        <!-- Foreground Service : maintient la projection cluster en background -->
        <service
            android:name=".ClusterService"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

        <!-- Service overlay bouton journal flottant -->
        <service
            android:name=".FloatingLogButton"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

        <!-- Service overlay icône de retour rapide au streaming -->
        <service
            android:name=".FloatingRemoteButton"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

        <!-- FileProvider : partage de fichiers .log avec les apps externes (email, messagerie…) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <provider
            android:name=".daemon.MirrorProvider"
            android:authorities="${applicationId}.mirrorprovider"
            android:exported="true" />


    </application>

</manifest>
