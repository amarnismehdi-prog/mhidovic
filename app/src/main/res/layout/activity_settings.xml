<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#f2f2f2">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:clipToPadding="false">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_header"
            android:textSize="26sp"
            android:textColor="#2E3440"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"
            android:gravity="center_horizontal"/>

        <!-- ══ SECTION 1 : TYPE DE CLUSTER ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:elevation="3dp"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:layout_marginHorizontal="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_cluster_type_title"
                android:textSize="18sp"
                android:textColor="#3B4252"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <RadioGroup
                android:id="@+id/rg_cluster_type"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rb_88"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cluster_label_88"
                    android:textSize="14sp"
                    android:padding="6dp"/>

                <RadioButton
                    android:id="@+id/rb_123"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cluster_label_123"
                    android:textSize="14sp"
                    android:padding="6dp"/>

                <RadioButton
                    android:id="@+id/rb_1025"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/cluster_label_1025"
                    android:textSize="14sp"
                    android:padding="6dp"/>

            </RadioGroup>
        </LinearLayout>

        <!-- ══ SECTION 2 : MARGES OVERSCAN ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:elevation="3dp"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:layout_marginHorizontal="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_overscan_section_title"
                android:textSize="18sp"
                android:textColor="#3B4252"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_overscan_desc"
                android:textSize="12sp"
                android:textColor="#4C566A"
                android:layout_marginBottom="12dp"/>

            <CheckBox
                android:id="@+id/cb_visual_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Utiliser le mode visuel directionnel"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <!-- Bloc Sliders Classique -->
            <LinearLayout
                android:id="@+id/ll_sliders_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                
                <!-- Gauche / Droite -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_inset_h_label"
                    android:textSize="14sp"
                    android:textColor="#3B4252"/>

                <TextView
                    android:id="@+id/tv_inset_h_value"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="80 px"
                    android:textSize="14sp"
                    android:textColor="#5E81AC"
                    android:textStyle="bold"
                    android:gravity="end"/>
            </LinearLayout>

            <SeekBar
                android:id="@+id/sb_inset_h"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="200"
                android:progress="80"
                android:layout_marginBottom="16dp"/>

            <!-- Haut / Bas -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_inset_v_label"
                    android:textSize="14sp"
                    android:textColor="#3B4252"/>

                <TextView
                    android:id="@+id/tv_inset_v_value"
                    android:layout_width="60dp"
                    android:layout_height="wrap_content"
                    android:text="50 px"
                    android:textSize="14sp"
                    android:textColor="#5E81AC"
                    android:textStyle="bold"
                    android:gravity="end"/>
            </LinearLayout>

            <SeekBar
                android:id="@+id/sb_inset_v"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="200"
                android:progress="50"
                android:layout_marginBottom="20dp"/>
            </LinearLayout>

            <!-- Mode Visuel -->
            <include layout="@layout/layout_visual_overscan" />

            <!-- Boutons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <Button
                    android:id="@+id/btn_apply_overscan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_btn_apply_overscan"
                    android:backgroundTint="#1565C0"
                    android:textColor="@color/text_primary"
                    android:layout_marginEnd="6dp"/>

                <Button
                    android:id="@+id/btn_reset_overscan"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_btn_reset_overscan"
                    android:backgroundTint="#607D8B"
                    android:textColor="@color/text_primary"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tv_overscan_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:background="#E5E9F0"
                android:padding="8dp"
                android:visibility="gone"/>

        </LinearLayout>

        <!-- ══ SECTION 3 : MISES À JOUR ══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#ffffff"
            android:elevation="3dp"
            android:padding="16dp"
            android:layout_marginBottom="16dp"
            android:layout_marginHorizontal="4dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_updates_title"
                android:textSize="18sp"
                android:textColor="#3B4252"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"/>

            <CheckBox
                android:id="@+id/cb_prerelease"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_prerelease_label"
                android:textSize="14sp"
                android:padding="6dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/settings_prerelease_hint"
                android:textSize="12sp"
                android:textColor="#888888"
                android:layout_marginTop="2dp"
                android:layout_marginStart="36dp"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
