<?xml version="1.0" encoding="utf-8"?>
<!--
  ClusterMapActivity layout — renders on Display 1 (1920×720 cluster)
  3D navigation map with HUD overlay and car cursor fixed at 78% from top
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Full-screen 3D Google Map -->
    <com.google.android.gms.maps.MapView
        android:id="@+id/cluster_map_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Top HUD strip: turn instruction + ETA -->
    <LinearLayout
        android:id="@+id/hud_top"
        android:layout_width="match_parent"
        android:layout_height="112dp"
        android:layout_gravity="top"
        android:background="#CC000000"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:visibility="gone">

        <!-- Turn direction icon -->
        <ImageView
            android:id="@+id/hud_turn_icon"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/ic_turn_straight"
            android:tint="#FFFFFF"
            android:contentDescription="turn"/>

        <!-- Distance to next turn + street name -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="16dp">

            <TextView
                android:id="@+id/hud_distance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textColor="#FFFFFF"
                android:textSize="36sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/hud_street"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#CCCCFF"
                android:textSize="20sp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- ETA block -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/hud_eta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/hud_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#AAAACC"
                android:textSize="16sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Car cursor fixed at 78% from top, centered horizontally -->
    <!-- Positioned programmatically in ClusterMapActivity.onMapReady() -->
    <ImageView
        android:id="@+id/cursor_car"
        android:layout_width="40dp"
        android:layout_height="60dp"
        android:layout_gravity="top|center_horizontal"
        android:src="@drawable/ic_car_cursor"
        android:contentDescription="car position"
        android:elevation="8dp"/>

    <!-- Speed badge — bottom-right corner -->
    <LinearLayout
        android:id="@+id/speed_badge"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        android:background="#CC1a1a2e"
        android:gravity="center"
        android:orientation="vertical"
        android:elevation="4dp">

        <TextView
            android:id="@+id/speed_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="48sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="km/h"
            android:textColor="#AAAACC"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Arrived banner (hidden until arrival) -->
    <TextView
        android:id="@+id/arrived_banner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="#CC2196F3"
        android:text="Vous êtes arrivé(e)"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:visibility="gone"
        android:elevation="12dp"/>

</FrameLayout>
