<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ll_visual_overscan"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:visibility="gone"
    android:layout_marginBottom="20dp">

    <!-- Représentation d'écran Cluster (Ratio 1920x720 => 16:6 => 320x120 dp) -->
    <FrameLayout
        android:layout_width="320dp"
        android:layout_height="120dp"
        android:background="#222222"
        android:layout_marginBottom="16dp">
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_cluster_border" />
        <!-- Zone Safe -->
        <FrameLayout
            android:id="@+id/fl_safe_zone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="10dp"
            android:background="#331565C0">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_dashed_border" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="APP"
                android:textStyle="bold"
                android:textColor="@color/text_accent"
                android:textSize="12sp"/>
        </FrameLayout>
    </FrameLayout>

    <!-- Contrôles directionnels -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center">
        <!-- V controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginEnd="32dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↕ Hauteur" android:textColor="@color/text_secondary" android:textSize="12sp"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                <Button android:id="@+id/btn_v_minus" android:layout_width="48dp" android:layout_height="36dp" android:text="➖" android:backgroundTint="@color/bg_button_secondary" android:textColor="@color/text_primary"/>
                <Button android:id="@+id/btn_v_plus" android:layout_width="48dp" android:layout_height="36dp" android:text="➕" android:layout_marginStart="8dp" android:backgroundTint="@color/bg_button_secondary" android:textColor="@color/text_primary"/>
            </LinearLayout>
        </LinearLayout>
        <!-- H controls -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↔ Largeur" android:textColor="@color/text_secondary" android:textSize="12sp"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="8dp">
                <Button android:id="@+id/btn_h_minus" android:layout_width="48dp" android:layout_height="36dp" android:text="➖" android:backgroundTint="@color/bg_button_secondary" android:textColor="@color/text_primary"/>
                <Button android:id="@+id/btn_h_plus" android:layout_width="48dp" android:layout_height="36dp" android:text="➕" android:layout_marginStart="8dp" android:backgroundTint="@color/bg_button_secondary" android:textColor="@color/text_primary"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
