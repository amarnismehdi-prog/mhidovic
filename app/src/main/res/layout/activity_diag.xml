<?xml version="1.0" encoding="utf-8"?>
<!--
    DiagActivity — M3 redesign (v0.9.88).
    Tests from previous versions have been wiped; new diagnostic tools will be added
    here from scratch. This is intentionally a clean slate with only the nav rail
    and a placeholder hero card.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="?attr/colorSurface">

    <!-- ============= Nav rail ============= -->
    <LinearLayout
        android:id="@+id/ll_nav_rail_diag"
        android:layout_width="96dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:background="@color/md_surface_container_low"
        android:paddingTop="14dp" android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/iv_nav_logo_diag"
            android:layout_width="48dp" android:layout_height="48dp"
            android:src="@mipmap/ic_launcher"
            android:padding="10dp"
            android:background="@drawable/bg_pulse_dot"
            android:contentDescription="@string/app_name"
            android:clickable="true" android:focusable="true"/>

        <ImageView
            android:id="@+id/nav_apps_diag"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="22dp"
            android:src="@drawable/ic_apps"
            android:padding="10dp"
            android:contentDescription="@string/main_nav_apps"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_apps"
            android:textSize="10sp" android:textColor="@color/md_on_surface_variant"
            android:layout_marginTop="2dp"/>

        <ImageView
            android:id="@+id/nav_settings_diag"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:src="@drawable/ic_tune"
            android:padding="10dp"
            android:contentDescription="@string/main_nav_settings"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_settings"
            android:textSize="10sp" android:textColor="@color/md_on_surface_variant"
            android:layout_marginTop="2dp"/>

        <ImageView
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:src="@drawable/ic_stethoscope"
            android:padding="10dp"
            android:background="@drawable/bg_nav_pill_active"
            android:contentDescription="@string/main_nav_diag"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_diag"
            android:textSize="10sp" android:textColor="@color/md_primary"
            android:textStyle="bold"
            android:layout_marginTop="2dp"/>

        <ImageView
            android:id="@+id/nav_sysinfo_diag"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:src="@drawable/ic_info"
            android:padding="10dp"
            android:contentDescription="@string/main_nav_sysinfo"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_sysinfo"
            android:textSize="10sp" android:textColor="@color/md_on_surface_variant"
            android:layout_marginTop="2dp"/>

        <ImageView
            android:id="@+id/nav_log_diag"
            android:layout_width="48dp" android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:src="@drawable/ic_notes"
            android:padding="10dp"
            android:contentDescription="@string/main_nav_log"
            android:clickable="true" android:focusable="true"/>
        <TextView
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/main_nav_log"
            android:textSize="10sp" android:textColor="@color/md_on_surface_variant"
            android:layout_marginTop="2dp"/>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
    </LinearLayout>

    <!-- ============= Main area ============= -->
    <LinearLayout
        android:layout_width="0dp" android:layout_weight="1"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="20dp" android:paddingEnd="20dp"
        android:paddingTop="20dp" android:paddingBottom="20dp">

        <!-- Top bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp" android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="@string/main_nav_diag"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"/>

            <TextClock
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:format12Hour="HH:mm"
                android:format24Hour="HH:mm"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/md_on_surface_variant"/>
        </LinearLayout>

        <!-- Placeholder hero -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/md_outline_variant"
            app:cardBackgroundColor="@color/md_surface_container_low">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:paddingStart="32dp" android:paddingEnd="32dp"
                android:paddingTop="48dp" android:paddingBottom="48dp">

                <ImageView
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:src="@drawable/ic_stethoscope"
                    android:padding="22dp"
                    android:background="@drawable/bg_diag_card_icon"
                    app:tint="@color/md_primary"
                    android:contentDescription="@string/main_nav_diag"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/diag_placeholder_title"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:gravity="center"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginStart="32dp"
                    android:layout_marginEnd="32dp"
                    android:text="@string/diag_placeholder_subtitle"
                    android:textSize="14sp"
                    android:textColor="@color/md_on_surface_variant"
                    android:gravity="center"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
