<?xml version="1.0" encoding="utf-8"?>
<!-- Tap = envoyer sur le cluster | Long press = menu contextuel -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="68dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="12dp"
    android:paddingEnd="4dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    android:background="?android:attr/selectableItemBackground">

    <ImageView
        android:id="@+id/iv_app_icon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_marginEnd="14dp"
        android:scaleType="fitCenter"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginEnd="4dp">

        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:ellipsize="end"
            android:singleLine="true"
            android:textColor="@color/text_primary"/>

        <TextView
            android:id="@+id/tv_app_category"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="@color/text_secondary"
            android:background="#22888888"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:layout_marginTop="2dp"
            android:visibility="gone"/>

        <!-- Container for Shortcuts -->
        <LinearLayout
            android:id="@+id/ll_shortcuts_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:visibility="gone" />
    </LinearLayout>

    <CheckBox
        android:id="@+id/cb_auto_launch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_state_auto"
        android:textSize="10sp"
        android:textColor="@color/text_secondary"
        android:layout_marginEnd="4dp"
        android:buttonTint="#FFC107"
        android:visibility="gone"/>

    <!-- Indicator: app currently displayed on the cluster -->
    <View
        android:id="@+id/view_active_indicator"
        android:layout_width="5dp"
        android:layout_height="32dp"
        android:background="#4CAF50"
        android:layout_marginStart="8dp"
        android:visibility="gone"/>

    <!-- Button "← Main screen" — visible only when the app is active on the cluster -->
    <Button
        android:id="@+id/btn_to_main"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="@string/btn_app_to_main"
        android:textSize="11sp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginStart="6dp"
        android:visibility="gone"/>

    <!-- Button "→ Cluster" — visible only when the app is on the main screen -->
    <Button
        android:id="@+id/btn_to_cluster"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="@string/btn_app_to_cluster"
        android:textSize="11sp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_marginStart="6dp"
        android:backgroundTint="#1565C0"
        android:visibility="gone"/>

    <!-- Button "✕ Kill" — always visible, allows killing the app even if it is on the cluster -->
    <Button
        android:id="@+id/btn_kill_app"
        android:layout_width="44dp"
        android:layout_height="40dp"
        android:text="✕"
        android:textSize="14sp"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:layout_marginStart="4dp"
        android:backgroundTint="#F44336"/>

</LinearLayout>
