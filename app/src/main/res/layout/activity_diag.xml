<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Titre -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Diagnostic de compatibilité"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vérifie quel mécanisme est disponible pour envoyer des apps sur l'écran dashboard (instrument cluster)."
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginBottom="20dp"/>

        <!-- ======================== TEST 1 ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 1 — Presentation API (méthode recommandée)"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Détecte si le cluster est exposé comme un display Android standard (DISPLAY_CATEGORY_PRESENTATION). C'est la méthode propre qui ne nécessite pas ADB."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_presentation_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="En attente du diagnostic…"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="12dp"
            android:background="#333333"
            android:layout_marginBottom="20dp"/>

        <!-- ======================== TEST 2 ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 2 — Réflexion setLaunchDisplayId"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Vérifie que ActivityOptions.setLaunchDisplayId() (méthode @hide AOSP) est accessible par réflexion Java à l'exécution. Nécessaire pour lancer n'importe quelle app tierce sur le display."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_reflection_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="En attente du diagnostic…"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="12dp"
            android:background="#333333"
            android:layout_marginBottom="20dp"/>

        <!-- ======================== TEST 3 ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 3 — ADB TCP local (méthode Freedom)"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tente une connexion sur 127.0.0.1:5037 et 127.0.0.1:5555 pour savoir si le daemon ADB local est joignable. Nécessite 'Débogage sans fil' activé dans les paramètres développeur."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_adb_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="En attente du diagnostic…"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="12dp"
            android:background="#333333"
            android:layout_marginBottom="24dp"/>

        <!-- ======================== TEST 4 ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 4 — Lancement effectif sur le cluster"
            android:textColor="#90CAF9"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tente réellement de lancer les Paramètres Android sur le display secondaire via setLaunchDisplayId(). Confirme que toute la chaîne fonctionne sur ce véhicule précis. L'app apparaîtra momentanément sur le cluster."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_launch_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="En attente du diagnostic…"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="12dp"
            android:background="#333333"
            android:layout_marginBottom="24dp"/>

        <!-- ======================== BOUTON ======================== -->
        <Button
            android:id="@+id/btn_run_diag"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lancer le diagnostic"
            android:textSize="15sp"
            android:layout_marginBottom="24dp"/>

        <!-- ======================== CONCLUSION ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CONCLUSION"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_conclusion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Lancez le diagnostic pour voir la conclusion."
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:padding="16dp"
            android:background="#333333"
            android:layout_marginBottom="32dp"/>

        <!-- ======================== TEST 5 — ADB LOCAL ======================== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 5 — Connexion ADB locale (dadb)"
            android:textColor="#A5D6A7"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Se connecte au daemon ADB de la tablette sur localhost:5555 (même mécanisme qu'Overdrive). Au premier lancement, un popup &#171;Autoriser le débogage USB ?&#187; apparaît — appuyez AUTORISER. Une fois autorisé, tente de débloquer toutes les permissions BYDAUTO_*_GET refusées via pm grant."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_adb_local"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connexion ADB locale + Grant permissions"
            android:textSize="14sp"
            android:backgroundTint="#2E7D32"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_adb_local_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appuyez sur le bouton pour lancer."
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#1A2A1A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_adb_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Partager le résultat TEST 5"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- ======================== TEST 6 — CLUSTER PROCESS ======================== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 6 — Quel process occupe le cluster ?"
            android:textColor="#FFCC80"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Interroge le système via ADB pour savoir quels packages BYD sont installés, lequel est actif sur le display secondaire (cluster), et vérifie si com.byd.automap et com.byd.launchermap existent bien sur ce véhicule. Copie aussi les APK cluster trouvés sur /sdcard pour analyse."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_cluster_probe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sonder le cluster + extraire APK (ADB requis)"
            android:textSize="14sp"
            android:backgroundTint="#E65100"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_cluster_probe_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appuyez sur le bouton (ADB doit être autorisé — TEST 5 d&#39;abord)."
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#1A1A2A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_cluster_probe_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Partager le résultat TEST 6"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- ======================== TEST 7 — AUTOSERVICE BINDER ======================== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 7 — Sonder android.gui.BYDAutoServer"
            android:textColor="#FFCC80"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appelle service call autoservice 3 (= transaction exacte de Freedom via Binder). Active aussi ADB TCP port 5555 pour récupérer les APKs extraits par adb pull depuis le PC."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_autoservice_probe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sonder autoservice + activer ADB TCP (ADB requis)"
            android:textSize="14sp"
            android:backgroundTint="#6A1B9A"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_autoservice_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appuyez sur le bouton (TEST 5 requis)."
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#1A1A2A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_autoservice_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Partager le résultat TEST 7"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- ======================== TEST 8 — ACTIVATION CLUSTER ======================== -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#444444"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 8 — Activer la projection sur le cluster"
            android:textColor="#A5D6A7"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠️ Véhicule à l&#39;arrêt, contact ON. Le cluster peut passer brièvement en &#34;Simple mode&#34; (mode hardware MCU, comportement normal au boot Android) puis revenir automatiquement. Aucun risque matériel."
            android:textColor="#FF8F00"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Commandes découvertes : sendInfo(1000,16)=plein écran, sendInfo(1000,1)=déconnecter flux natif, sendInfo(1000,0)=restaurer. Lit aussi /system/etc/container_comm_cfg.json pour voir la whitelist."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_cluster_activ"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activer projection cluster + lire whitelist (ADB requis)"
            android:textSize="14sp"
            android:backgroundTint="#1B5E20"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_cluster_activ_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Appuyez sur le bouton (TEST 5 requis)."
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="12dp"
            android:background="#1A1A2A"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_cluster_activ_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Partager le résultat TEST 8"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- TEST 9 : Sonde VirtualDisplay (polling + registerCallback) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 9 — Sonde VirtualDisplay"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pourquoi le VirtualDisplay n'apparaît-il pas ? Polling 10×500ms + registerCallback (#4) + SurfaceFlinger layers."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_vd_probe"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ Lancer TEST 9"
            android:textSize="15sp"
            android:backgroundTint="#6A1E8A"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_vd_probe_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(résultat TEST 9)"
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="#1A1A2A"
            android:padding="8dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_vd_probe_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Partager le résultat TEST 9"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- TEST 10 : Lancement sur display ID 1 (cluster) — WindowManagement insight -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 10 — Lancement sur Display 1 (Cluster)"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sur BYD DiLink 3.0, le cluster = display ID 1 dans IActivityManager (pas dans DisplayManager). sendInfo(1000,16) + am start --display 1."
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_display1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ Lancer TEST 10"
            android:textSize="15sp"
            android:backgroundTint="#E65100"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_display1_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(résultat TEST 10)"
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:background="#1A1200"
            android:padding="8dp"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_display1_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Partager le résultat TEST 10"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- TEST 11 : AutoContainer Whitelist — sharedUserId + container_comm_cfg -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 11 — AutoContainer Whitelist (sharedUserId + container_comm_cfg)"
            android:textColor="#FFCC00"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"/>

        <Button
            android:id="@+id/btn_whitelist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ Lancer TEST 11"
            android:textSize="13sp"
            android:backgroundTint="#4A148C"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_whitelist_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(résultat TEST 11)"
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:background="#111111"
            android:layout_marginBottom="4dp"/>

        <Button
            android:id="@+id/btn_whitelist_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:text="Partager le résultat TEST 11"
            android:layout_marginBottom="16dp"/>

        <!-- TEST 12a : Sauvegarde container_comm_cfg.json (lecture seule) -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 12a — Sauvegarder whitelist (lecture seule, AVANT de patcher)"
            android:textColor="#66BB6A"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="4dp"/>

        <Button
            android:id="@+id/btn_whitelist_backup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ TEST 12a — Sauvegarder (aucune modification)"
            android:textSize="13sp"
            android:backgroundTint="#1B5E20"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_whitelist_backup_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(résultat TEST 12a)"
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:background="#111111"
            android:layout_marginBottom="4dp"/>

        <Button
            android:id="@+id/btn_whitelist_backup_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:text="Partager le résultat TEST 12a"
            android:layout_marginBottom="12dp"/>

        <!-- TEST 12b : Patch container_comm_cfg.json — ajouter com.byd.myapp -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TEST 12b — Patcher whitelist (MODIFIE /system — nécessite 12a)"
            android:textColor="#FF6600"
            android:textStyle="bold"
            android:textSize="13sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"/>

        <Button
            android:id="@+id/btn_whitelist_patch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="▶ TEST 12b — Patcher (nécessite sauvegarde 12a)"
            android:textSize="13sp"
            android:backgroundTint="#B71C1C"
            android:layout_marginBottom="4dp"/>

        <!-- TEST 12c : Restauration depuis backup -->
        <Button
            android:id="@+id/btn_whitelist_restore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="↩ TEST 12c — Restaurer fichier original (depuis backup sdcard)"
            android:textSize="13sp"
            android:backgroundTint="#4E342E"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_whitelist_patch_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="(résultat TEST 12b / 12c)"
            android:textColor="#CCCCCC"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:background="#111111"
            android:layout_marginBottom="4dp"/>

        <Button
            android:id="@+id/btn_whitelist_patch_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:backgroundTint="#1565C0"
            android:text="Partager le résultat TEST 12b/12c"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
