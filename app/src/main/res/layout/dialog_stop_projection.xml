<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/md_surface_container_high"
    android:paddingTop="12dp"
    android:paddingBottom="20dp"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="Overdraw">

    <!-- Drag handle -->
    <View
        android:layout_width="32dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@color/md_on_surface_variant"
        android:alpha="0.4"/>

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/main_btn_stop_mirror"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/md_on_surface"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/stop_sheet_subtitle"
            android:textSize="13sp"
            android:textColor="@color/md_on_surface_variant"/>
    </LinearLayout>

    <!-- Action: restore origin cluster (uses screen size from Settings) -->
    <LinearLayout
        android:id="@+id/sheet_action_origin_cluster"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="72dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="?android:attr/selectableItemBackground">

        <ImageView
            android:contentDescription="@null"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginEnd="20dp"
            android:src="@drawable/ic_refresh"
            android:tint="@color/md_primary"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/btn_origin_cluster"
                android:textSize="16sp"
                android:textColor="@color/md_on_surface"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="@string/stop_sheet_origin_desc"
                android:textSize="12sp"
                android:textColor="@color/md_on_surface_variant"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
