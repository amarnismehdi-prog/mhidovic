<?xml version="1.0" encoding="utf-8"?>
<!--
  TabletDemoActivity — standalone tablet layout.
  Left  (60%): cluster simulation — 8:3 map with 3D nav + HUD overlays
  Right (40%): NavCast control panel — Places search + ETA + nav buttons
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#1a1a1a">

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- LEFT: Cluster simulation (3D map in 8:3 frame)                -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1.6"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title label -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="CLUSTER — 1920×720 (simulation 8:3)"
            android:textColor="#4488FF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:gravity="center"
            android:paddingBottom="8dp"/>

        <!-- 8:3 aspect map container — height set programmatically -->
        <FrameLayout
            android:id="@+id/demo_map_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#e8e4dc">

            <com.google.android.gms.maps.MapView
                android:id="@+id/demo_map_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

            <!-- Route polyline + car cursor are drawn by the map; -->
            <!-- Cursor ImageView positioned programmatically at 78% from top -->
            <ImageView
                android:id="@+id/demo_cursor"
                android:layout_width="40dp"
                android:layout_height="60dp"
                android:layout_gravity="top|center_horizontal"
                android:src="@drawable/ic_car_chevron"
                android:contentDescription="car"
                android:elevation="8dp"/>

            <!-- HUD overlay — top strip -->
            <LinearLayout
                android:id="@+id/demo_hud"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="top"
                android:background="#CC000000"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="10dp"
                android:visibility="gone">

                <ImageView
                    android:id="@+id/demo_turn_icon"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_turn_straight"
                    android:tint="#FFFFFF"
                    android:contentDescription="turn"/>

                <TextView
                    android:id="@+id/demo_distance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:paddingStart="10dp"/>

                <TextView
                    android:id="@+id/demo_street"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#CCCCFF"
                    android:textSize="13sp"
                    android:paddingStart="8dp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:id="@+id/demo_eta_hud"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Speed badge — bottom right -->
            <LinearLayout
                android:id="@+id/demo_speed_badge"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="10dp"
                android:background="#CC1a1a2e"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/demo_speed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="km/h"
                    android:textColor="#AAAACC"
                    android:textSize="8sp"/>
            </LinearLayout>

            <!-- Arrived banner -->
            <TextView
                android:id="@+id/demo_arrived"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:background="#CC2196F3"
                android:text="Vous êtes arrivé(e)"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:padding="16dp"
                android:visibility="gone"
                android:elevation="12dp"/>
        </FrameLayout>

        <!-- GPS status below map -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="8dp">

            <View
                android:id="@+id/demo_gps_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:layout_marginEnd="6dp"
                android:background="#888888"/>

            <TextView
                android:id="@+id/demo_gps_status"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="GPS: en attente…"
                android:textColor="#888888"
                android:textSize="12sp"/>

            <TextView
                android:id="@+id/demo_coords"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="#556688"
                android:textSize="11sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#222244"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"/>

    <!-- ══════════════════════════════════════════════════════════════ -->
    <!-- RIGHT: NavCast control panel                                   -->
    <!-- ══════════════════════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="16dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_navigation"
                android:tint="#4488FF"
                android:contentDescription="@null"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NavCast Demo"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/demo_nav_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Saisissez une destination"
                    android:textColor="#8888AA"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Places search field -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/demo_til_address"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Rechercher une destination…"
            app:boxStrokeColor="#4488FF"
            app:hintTextColor="#8888AA"
            app:endIconMode="clear_text">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/demo_et_address"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPostalAddress|textCapWords"
                android:imeOptions="actionSearch"
                android:maxLines="1"
                android:textColor="#FFFFFF"
                android:textColorHint="#556688"/>

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Autocomplete suggestions RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/demo_rv_suggestions"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            android:clipToPadding="false"/>

        <!-- ETA card — shown while navigating -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/demo_card_eta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cardBackgroundColor="#1a1a2e"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:strokeColor="#334466">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/demo_eta_dest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#8899CC"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/demo_eta_step"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end"
                        android:paddingStart="12dp">

                        <TextView
                            android:id="@+id/demo_eta_time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#FFFFFF"
                            android:textSize="18sp"
                            android:textStyle="bold"/>

                        <TextView
                            android:id="@+id/demo_eta_dist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textColor="#8899CC"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Navigate button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/demo_btn_go"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="52dp"
            android:text="Naviguer"
            android:textSize="15sp"
            app:cornerRadius="26dp"
            app:icon="@drawable/ic_navigation"
            app:iconGravity="textStart"
            app:iconSize="20dp"
            android:visibility="gone"/>

        <!-- Stop navigation button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/demo_btn_stop"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minHeight="52dp"
            android:text="Arrêter la navigation"
            android:textSize="15sp"
            app:cornerRadius="26dp"
            app:icon="@drawable/ic_stop"
            app:iconGravity="textStart"
            app:iconSize="20dp"
            android:visibility="gone"/>

        <!-- Spacer -->
        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1"/>

        <!-- Info footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mode démo — la navigation cluster sera sur l'écran de bord BYD"
            android:textColor="#334466"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingTop="8dp"/>

    </LinearLayout>

</LinearLayout>
