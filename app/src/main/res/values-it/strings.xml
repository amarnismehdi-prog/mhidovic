    <!-- DiagActivity — layout labels -->
    <string name="diag_title">Diagnostica Compatibilità</string>
    <string name="diag_subtitle">Verifica quale meccanismo è disponibile per inviare app allo schermo dashboard (instrument cluster).</string>
    <string name="diag_test1_title">TEST 1 — Connessione ADB locale (dadb)</string>
    <string name="diag_test1_desc">Si connette al daemon ADB del tablet su localhost:5555 (stesso meccanismo di Overdrive). Al primo avvio compare un popup «Consenti debug USB?» — premere CONSENTI. Dopodiché tenta di sbloccare tutti i permessi BYDAUTO_*_GET negati tramite pm grant.</string>
    <string name="diag_press_hint">Premere il pulsante per avviare.</string>
    <string name="diag_share_result1_btn">Condividi risultato TEST 1</string>
    <string name="diag_test2_title">TEST 2 — Ripristino cluster</string>
    <string name="diag_test2_desc">Su BYD DiLink 3.0 il cluster = display ID 1 in IActivityManager (non in DisplayManager). sendInfo(1000,16) + am start --display 1.</string>
    <string name="diag_launch_test2_btn">▶ Avvia TEST 2</string>
    <string name="diag_result_test2_hint">(risultato TEST 2)</string>
    <string name="diag_share_result2_btn">Condividi risultato TEST 2</string>
    <string name="diag_test3_title">TEST 3 — Dimensione schermo cluster (risoluzione Qt)</string>
    <string name="diag_test3_desc">Dimensione schermo cluster: cmd 29=8,8\" (Atto3/Dolphin) / cmd 30=12,3\" (Seal EU ✅) / cmd 31=10,25\". Confermato 16/04/2026: cmd 30 = risoluzione corretta Seal EU. Ripristino: cmd30 + wm reset.</string>
    <string name="diag_size_88_btn">▶ 8,8\"\n(cmd 29)\nAtto3/Dolphin</string>
    <string name="diag_size_123_btn">▶ 12,3\"\n(cmd 30)\nSeal EU ✅</string>
    <string name="diag_size_1025_btn">▶ 10,25\"\n(cmd 31)\naltri modelli</string>
    <string name="diag_size_restore_btn">🔄 Ripristina predefinito (cmd 30 + wm reset)</string>
    <string name="diag_size_full_btn">📊 Diagnosi completa (~8 s)</string>
    <string name="diag_test3_hint_text">Premere un pulsante (ADB deve essere autorizzato — eseguire prima TEST 1).</string>
    <string name="diag_share_result3_btn">Condividi risultato TEST 3</string>
    <string name="diag_launch_test4_btn">▶ Avvia TEST 4 — Broadcast BootReceiver</string>
    <string name="diag_result_test4_hint">(risultato TEST 4)</string>
    <string name="diag_share_result4_btn">Condividi risultato TEST 4</string>
    <string name="diag_test5_title">TEST 5 — Gestione MirrorDaemon (uid=2000)</string>
    <string name="diag_test5_desc">Verifica e controlla il processo MirrorDaemon (com.byd.myapp.mirrordaemon). Più istanze simultanee causano schermo nero.</string>
    <string name="diag_scan_daemon_btn">🔍 Scansiona MirrorDaemon attivi</string>
    <string name="diag_scan_result_hint">(risultato scansione)</string>
    <string name="diag_kill_daemon_btn">☠ Termina tutti i MirrorDaemon</string>
